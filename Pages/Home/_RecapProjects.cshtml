@{
    ViewData["Title"] = "Projets";
}

<section class="recentProjects">
    <div class="sectionContent recentProjectsContent">
        <div class="articleProjects" aria-label="Projets récents">
            <div>
                <h2>Projets récents</h2>
                <p>Trouvez ci-dessous quelques-uns de mes projets qui mettent en pratique mes compétences.</p>
            </div>
            <div class="listRecentProjects">

                <article class="cardProject clickable">
                    <div class="cardImageWrapper">
                        <img src="~/gif/Medicalib-gif.gif" alt="Gif du projet HealthRiskEngine" class="cardImage" />
                        <div class="cardIcons">
                            <a href="https://github.com/Steven-Riviere/HealthRiskEngine" target="_blank" rel="noopener noreferrer">
                                <img src="~/images/github-black.svg" alt="healthrisk-github" class="icon" />
                            </a>
                        </div>
                    </div>
                    <div class="cardProjectDescription">
                        <h3>Médicalib</h3>
                        <p>
                            Application basée sur une architecture microservices permettant la gestion de patients
                            et l’analyse de risques médicaux (diabète, cancer).
                            Le projet utilise une API Gateway, Docker et plusieurs services indépendants.
                        </p>
                        <ul class="tags" aria-label="technologies utilisées">
                            <li class="tag">ASP.NET Core MVC (Razor)</li>
                            <li class="tag">C#</li>
                            <li class="tag">Docker</li>
                        </ul>
                    </div>
                </article>

                <article class="cardProject clickable">
                    <div class="cardImageWrapper">
                        <img src="~/gif/PretImmo.gif" alt="Gif du projet HealthRiskEngine" class="cardImage" />
                        <div class="cardIcons">
                            <a href="https://github.com/Steven-Riviere/AmortizationCalculator" target="_blank" rel="noopener noreferrer">
                                <img src="~/images/github-black.svg" alt="amortization-github" class="icon" />
                            </a>
                            <a href="https://pretimmosimulation.onrender.com/" target="_blank" rel="noopener noreferrer">
                                <img src="~/images/arrow.svg" alt="siteweb" class="icon" />
                            </a>
                        </div>
                    </div>
                    <div class="cardProjectDescription">
                        <h3>Prêt Immobilier</h3>
                        <p>
                            Application permettant de simuler un prêt immobilier avec ou sans assurance.
                            L’utilisateur peut configurer les paramètres (durée, taux, différé, assurance)
                            et obtenir un tableau d’amortissement détaillé ainsi qu’un export PDF.
                        </p>
                        <ul class="tags" aria-label="technologies utilisées">
                            <li class="tag">QuestPDF</li>
                            <li class="tag">ASP.NET Core MVC (Razor)</li>
                            <li class="tag">C#</li>
                        </ul>
                    </div>
                </article>

                <article class="cardProject clickable">
                    <div class="cardImageWrapper">
                        <img src="~/images/ecomod.webp" alt="Capture d'écran d'un mod de coopération du jeu Eco sur les boites aux lettres" class="cardImage" />
                        <div class="cardIcons">
                            <a href="https://github.com/Steven-Riviere/Eco-Mod" target="_blank" rel="noopener noreferrer">
                                <img src="~/images/github-black.svg" alt="mod-github" class="icon" />
                            </a>
                            <a href="https://mod.io/g/eco?_sort=name" target="_blank" rel="noopener noreferrer">
                                <img src="~/images/arrow.svg" alt="modio" class="icon" />
                            </a>
                        </div>
                    </div>
                    <div class="cardProjectDescription">
                        <h3>Eco-Mod BAL</h3>
                        <p>
                            Mod développé pour le jeu ECO ajoutant plusieurs types de boîtes aux lettres
                            adaptées à la progression des joueurs.
                            Le projet a été conçu en collaboration avec une équipe de la communauté.
                            Le mod a été publié sur
                            <a href="https://mod.io/g/eco?_sort=name" target="_blank" rel="noopener noreferrer">mod.io</a>,
                            permettant à la communauté de découvrir et d’utiliser ces ajouts dans leurs parties.
                        </p>
                        <ul class="tags" aria-label="technologies utilisées">
                            <li class="tag">Eco Modding</li>
                            <li class="tag">Unity</li>
                            <li class="tag">C#</li>
                        </ul>
                    </div>
                </article>
            </div>

            <button type="button" aria-label="Voir tous mes projets" onclick="window.location.href='/Projects'">
                Voir tous mes projets
                <i class="fa-solid fa-arrow-right"></i>
            </button>
        </div>
    </div>
</section>