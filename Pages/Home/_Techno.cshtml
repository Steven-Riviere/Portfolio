@{
    ViewData["Title"] = "Techno";
}
<section class="technoSection">
    <br />
    <div class="sectionContent technoContent">
        <article class="prefTechno">
            <div>
                <h2>Technologies préférées</h2>
                <p>Stack que j’apprécie pour le développement d’applications web et back-office, orienté backend .NET</p>
            </div>
            <ul class="iconsTech">
                <li class="iconsPrefTech">
                    <img src="~/images/net.webp" alt="dotnet" class="icon" />
                    <p>ASP.NET Core (C#)</p>
                </li>
                <li class="iconsPrefTech">
                    <img src="~/images/restapi.png" alt="restapi" class="icon" />
                    <p>REST API</p>
                </li>
                <li class="iconsPrefTech">
                    <img src="~/images/js.svg" alt="javascript" class="icon" />
                    <p>JavaScript (ES6+)</p>
                </li>
                <li class="iconsPrefTech">
                    <img src="~/images/react.svg" alt="react" class="icon" />
                    <p>React (JavaScript)</p>
                </li>
            </ul>

        </article>
    </div>
    <br />
</section>